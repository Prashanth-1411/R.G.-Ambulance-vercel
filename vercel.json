{
    "version": 2,
    "framework": null,
    "buildCommand": null,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php",
            "config": {
                "memory": 512,
                "maxDuration": 30
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "cleanUrls": true
}
